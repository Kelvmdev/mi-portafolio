# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore: NUNCA se sube al repo.
# Reinicia `npm run dev` después de editarlo (solo se lee al arrancar).

# Contraseña del panel /admin (la que tú quieras)
ADMIN_PASSWORD=

# Token PAT classic de GitHub con scope "public_repo" (repo público)
GITHUB_TOKEN=
GITHUB_OWNER=Kelvmdev
GITHUB_REPO=mi-portafolio
GITHUB_BRANCH=main
