---
import { imagenOptimizada } from "../lib/img";

interface Props {
  titulo: string;
  marca?: string;
  descripcion: string;
  metrica?: string;
  tags?: string[];
  imagen?: string;
  badge?: string;
  urlVivo?: string;
  urlRepo?: string;
}

const { titulo, marca, descripcion, metrica, tags = [], imagen, badge, urlVivo, urlRepo } = Astro.props;
const img = imagen ? imagenOptimizada(imagen, 600) : "";
---

<article
  class="group overflow-hidden rounded-xl border border-line bg-ink-2 transition duration-300 hover:-translate-y-1 hover:border-muted-2"
>
  <div class="relative flex aspect-[2/1] items-end overflow-hidden bg-linear-to-br from-[#2a2330] to-[#171320] p-4">
    {
      img && (
        <img
          src={img}
          alt={titulo}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
      )
    }
    {badge && (
      <span class="absolute top-3.5 right-3.5 z-10 rounded-md bg-rosa px-2 py-1 font-mono text-[11px] font-bold text-white">
        {badge}
      </span>
    )}
    {marca && !img && (
      <h4 class="relative font-display text-2xl font-bold text-white/90">{marca}</h4>
    )}
  </div>

  <div class="p-5">
    <h3 class="font-display text-[19px] font-bold">{titulo}</h3>
    <p class="mt-1.5 text-[13.5px] text-muted">{descripcion}</p>
    {metrica && <p class="mt-3 font-mono text-xs font-medium text-rosa">{metrica}</p>}

    {tags.length > 0 && (
      <div class="mt-3.5 flex flex-wrap gap-2">
        {tags.map((t) => (
          <span class="rounded-full border border-line px-2 py-0.5 font-mono text-[11px] text-muted">{t}</span>
        ))}
      </div>
    )}

    <div class="mt-4 flex flex-wrap gap-4 text-[13px] font-semibold">
      {urlVivo && (
        <a
          href={urlVivo}
          target="_blank"
          rel="noopener noreferrer"
          class="border-b border-rosa pb-0.5 text-bone transition hover:text-rosa"
        >
          Sitio en vivo ↗
        </a>
      )}
      {urlRepo && (
        <a
          href={urlRepo}
          target="_blank"
          rel="noopener noreferrer"
          class="border-b border-rosa pb-0.5 text-bone transition hover:text-rosa"
        >
          Código ↗
        </a>
      )}
    </div>
  </div>
</article>
