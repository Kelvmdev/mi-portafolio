---
import Layout from "../layouts/Layout.astro";
import Boton from "../components/Boton.astro";
import { site } from "../lib/content";
---

<Layout title={`¡Gracias! — ${site.nombre}`} description="Recibí tu mensaje. Te respondo pronto." noindex>
  <main id="contenido" tabindex="-1" class="mx-auto flex min-h-[70vh] max-w-[1180px] flex-col items-center justify-center px-[clamp(20px,5vw,48px)] py-20 text-center">
    <span class="font-mono text-xs uppercase tracking-[0.22em] text-rosa">Mensaje recibido</span>
    <h1 class="mt-4 font-display text-[clamp(40px,8vw,72px)] font-bold tracking-tight text-rosa">¡Gracias!</h1>
    <p class="mt-4 max-w-[44ch] text-muted">
      Recibí tu información correctamente. Te respondo pronto por correo o WhatsApp.
    </p>
    <Boton href="/" variant="secundario" class="mt-8">← Volver al inicio</Boton>
  </main>
</Layout>
